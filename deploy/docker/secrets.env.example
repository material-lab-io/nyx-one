# /data/nyx/secrets.env — Nyx runtime secrets
# Copy to /data/nyx/secrets.env and fill in real values

# WhatsApp DM allowlist (comma-separated phone numbers)
NYX_WA_DM_ALLOWLIST=+917259620848,+919818452569

# WhatsApp group policy (open/allowlist/deny)
NYX_WA_GROUP_POLICY=open

# WhatsApp group config (JSON)
NYX_WA_GROUPS={"120363423123267841@g.us":{"requireMention":false},"120363404614075738@g.us":{"requireMention":false}}

# Mayor bridge (optional — for gt mail integration)
MAYOR_BRIDGE_URL=http://127.0.0.1:19000
MAYOR_BRIDGE_TOKEN=YOUR_MAYOR_BRIDGE_TOKEN

# WhatsApp credentials (base64 creds.json from charlie account)
# Generate: cat /data/nyx/creds/creds.json | base64 -w0
# Leave empty to trigger QR scan on first run
WHATSAPP_CREDS_JSON=

# Claude Code conversation context limit
NYX_MAX_HISTORY=20
