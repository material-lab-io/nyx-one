# Nyx Claude Code + Baileys Container
# Lightweight Node.js image — no openclaw/chromium needed
FROM node:22-slim

LABEL maintainer="nyx-one"
LABEL description="Nyx: Claude Code + Baileys-direct WhatsApp bridge"

# System deps: curl (healthcheck + downloads), git (claude needs it), ca-certs
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
# Authenticates via CLAUDE_CODE_OAUTH_TOKEN env var (from k8s secret)
RUN npm install -g @anthropic-ai/claude-code

# App directory
WORKDIR /app

# Copy Baileys bridge
COPY deploy/baileys/package.json ./
RUN npm install --omit=dev

COPY deploy/baileys/baileys-bridge.js ./

# Patch Baileys: use allSettled so fetchProps failure doesn't abort executeInitQueries
RUN sed -i 's/await Promise\.all(\[fetchProps(), fetchBlocklist(), fetchPrivacySettings()\])/await Promise.allSettled([fetchProps(), fetchBlocklist(), fetchPrivacySettings()])/' \
    /app/node_modules/@whiskeysockets/baileys/lib/Socket/chats.js

# Copy Claude Code identity config (CLAUDE.md in workdir is picked up automatically)
COPY deploy/claude-config/nyx/CLAUDE.md ./CLAUDE.md

# Install Linear CLI
COPY deploy/linear-cli/package.json /app/linear-cli/
RUN cd /app/linear-cli && npm install --omit=dev
COPY deploy/linear-cli/linear-cli.js /app/linear-cli/
RUN printf '#!/bin/sh\nexec node /app/linear-cli/linear-cli.js "$@"\n' > /usr/local/bin/linear \
    && chmod +x /usr/local/bin/linear

# Copy mayor bridge helper (available in PATH)
COPY deploy/mayor-bridge/nyx-to-mayor /usr/local/bin/nyx-to-mayor
RUN chmod +x /usr/local/bin/nyx-to-mayor

# Copy Linear ticket helper (available in PATH)
COPY deploy/mayor-bridge/nyx-to-linear /usr/local/bin/nyx-to-linear
RUN chmod +x /usr/local/bin/nyx-to-linear

# Copy notes helper (available in PATH)
COPY deploy/mayor-bridge/nyx-notes /usr/local/bin/nyx-notes
RUN chmod +x /usr/local/bin/nyx-notes

# Copy entrypoint
COPY deploy/docker/entrypoint-bridge.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Data volume: Baileys creds + conversation history
# Auth via CLAUDE_CODE_OAUTH_TOKEN env var — no .claude volume needed
VOLUME ["/data/nyx"]

ENV BRIDGE_TYPE=baileys
ENV AGENT_NAME=nyx
ENV BRIDGE_DATA_DIR=/data/nyx
ENV BRIDGE_CLAUDE_WORKDIR=/app
ENV BRIDGE_CLAUDE_BIN=claude

# Health check via HTTP health server (started by bridge)
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8080/ || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
