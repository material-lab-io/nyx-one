# Nyx Claude Code + Baileys Container
# Lightweight Node.js image — no openclaw/chromium needed
FROM node:22-slim

LABEL maintainer="nyx-one"
LABEL description="Nyx: Claude Code + Baileys-direct WhatsApp bridge"

# System deps: curl (healthcheck + downloads), git (claude needs it), ca-certs
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
# Authenticates via ~/.claude credentials (mount as volume)
RUN npm install -g @anthropic-ai/claude-code

# App directory
WORKDIR /app

# Copy Baileys bridge
COPY deploy/baileys/package.json ./
RUN npm install --omit=dev

COPY deploy/baileys/baileys-bridge.js ./

# Copy Claude Code identity config (CLAUDE.md in workdir is picked up automatically)
COPY deploy/claude-config/CLAUDE.md ./CLAUDE.md

# Copy mayor bridge helper (available in PATH)
COPY deploy/mayor-bridge/nyx-to-mayor /usr/local/bin/nyx-to-mayor
RUN chmod +x /usr/local/bin/nyx-to-mayor

# Copy entrypoint
COPY deploy/docker/entrypoint-nyx.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Data volume: Baileys creds + conversation history + claude credentials
# Mount /data/nyx for Baileys state, /root/.claude for Claude Code auth
VOLUME ["/data/nyx", "/root/.claude"]

ENV NYX_DATA_DIR=/data/nyx
ENV NYX_CLAUDE_WORKDIR=/app
ENV NYX_CLAUDE_BIN=claude

# Health check: verify the bridge process is alive
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD pgrep -f "node.*baileys-bridge" > /dev/null || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
