[Unit]
Description=Mayor Mail Bridge (container → gt mail)
After=network.target

[Service]
Type=simple
User=kanaba
EnvironmentFile=/data/mayor-bridge/secrets.env
ExecStart=/usr/bin/node /home/kanaba/gt/nyx_one/crew/nyx/deploy/mayor-bridge/mayor-bridge.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
