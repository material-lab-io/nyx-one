#!/bin/bash
# nyx-send-email — Backward-compat shim that forwards to `nyx-email send`.
# Preserved so older references (CLAUDE.md, docs, scripts) keep working.
#
# Usage:
#   nyx-send-email "to@email.com" "Subject" "Body text"
#   nyx-send-email "to@email.com" "Subject" "Body text" --attach /path/to/file

set -euo pipefail

TO="${1:?Usage: nyx-send-email \"to\" \"subject\" \"body\" [--attach /path/to/file]}"
SUBJECT="${2:?Usage: nyx-send-email \"to\" \"subject\" \"body\" [--attach /path/to/file]}"
BODY="${3:?Usage: nyx-send-email \"to\" \"subject\" \"body\" [--attach /path/to/file]}"
shift 3

ARGS=(send --to "$TO" --subject "$SUBJECT" --body "$BODY")
while [ $# -gt 0 ]; do
  case "$1" in
    --attach) ARGS+=(--attach "$2"); shift 2;;
    *) echo "Unknown argument: $1" >&2; exit 1;;
  esac
done

exec nyx-email "${ARGS[@]}"
